    "import pandas as pd\n",
    "import glob\n",
    "\n",
    "files = glob.glob(\"../data/raw/*.csv\")\n",
    "df = []\n",
    "for f in files:\n",
    "    csv = pd.read_csv(f)\n",
    "    df.append(csv)\n",
    "df = pd.concat(df)\n",
    "\n",
    "# print(df.shape)\n",
    "# print(df.head())\n",
    "df['Scientific name'].value_counts()[:10]"
   ]
  }
